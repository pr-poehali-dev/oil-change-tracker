      "expectedStatus": 200,
      "expectedBody": { "oilInterval": 5000 },
      "bodyMatcher": "partial"
    },
    {
      "name": "Ошибка без параметров",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": { "error": "brand, model, year обязательны" },
      "bodyMatcher": "partial"
    }
  ]
}
