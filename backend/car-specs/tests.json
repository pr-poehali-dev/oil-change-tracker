{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Двигатели Toyota Camry",
      "method": "POST",
      "path": "/",
      "body": { "brand": "Toyota", "model": "Camry", "year": "2010", "mode": "engines" },
      "expectedStatus": 200
    },
    {
      "name": "Расходники mode=consumables",
      "method": "POST",
      "path": "/",
      "body": { "brand": "Toyota", "model": "Camry", "year": "2020", "mode": "consumables", "carId": "nonexistent_test_999" },
      "expectedStatus": 200
    },
    {
      "name": "Ошибка без параметров",
      "method": "POST",
      "path": "/",
      "body": {},
      "expectedStatus": 400
    },
    {
      "name": "VIN декодирование Toyota",
      "method": "POST",
      "path": "/",
      "body": { "mode": "vin", "vin": "JTDBR32E230012345" },
      "expectedStatus": 200
    },
    {
      "name": "VIN невалидная длина",
      "method": "POST",
      "path": "/",
      "body": { "mode": "vin", "vin": "12345" },
      "expectedStatus": 200
    },
    {
      "name": "Код кузова Toyota GX110",
      "method": "POST",
      "path": "/",
      "body": { "mode": "vin", "vin": "GX110-6001234" },
      "expectedStatus": 200
    },
    {
      "name": "Код кузова Nissan ER34",
      "method": "POST",
      "path": "/",
      "body": { "mode": "vin", "vin": "ER34" },
      "expectedStatus": 200
    },
    {
      "name": "СТС без фото — ошибка",
      "method": "POST",
      "path": "/",
      "body": { "mode": "sts_photo", "image": "" },
      "expectedStatus": 400
    },
    {
      "name": "Фото авто Toyota Camry",
      "method": "POST",
      "path": "/",
      "body": { "mode": "car_image", "brand": "Toyota", "model": "Camry", "year": "2015" },
      "expectedStatus": 200
    }
  ]
}