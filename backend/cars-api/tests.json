{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "GET список автомобилей пользователя",
      "method": "GET",
      "path": "/",
      "headers": {"X-User-Id": "test-user-uuid-123"},
      "expectedStatus": 200
    },
    {
      "name": "Создать автомобиль для пользователя",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "test-user-uuid-123"},
      "body": {
        "action": "create_car",
        "id": "test_car_uuid_2020",
        "brand": "Toyota",
        "model": "Test",
        "year": "2020",
        "oilInterval": 10000,
        "guides": [],
        "custom": true,
        "specs": []
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Удалить автомобиль",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "test-user-uuid-123"},
      "body": {
        "action": "delete_car",
        "id": "test_car_uuid_2020"
      },
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Генерация VAPID-ключей",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate_vapid"},
      "expectedStatus": 200,
      "expectedBody": {"publicKey": "string", "privateKey": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Публичный VAPID-ключ",
      "method": "POST",
      "path": "/",
      "body": {"action": "vapid_public_key"},
      "expectedStatus": 200
    },
    {
      "name": "Подписка без данных — ошибка",
      "method": "POST",
      "path": "/",
      "headers": {"X-User-Id": "test-user-uuid-123"},
      "body": {"action": "save_subscription", "subscription": {}},
      "expectedStatus": 400
    }
  ]
}